APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Kosongkan untuk URL relatif /storage/... (disarankan di local).
# FILESYSTEM_PUBLIC_URL=https://cdn.example.com/storage

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

ADMIN_ROUTE_PREFIX=app
ADMIN_ROUTE_NAME=app
ADMIN_MENU_DOMAIN=app

# Registrasi publik (set false di production)
REGISTRATION_ENABLED=true

# Kredensial superadmin saat seeding (WAJIB ganti di production)
SUPERADMIN_EMAIL=superadmin@example.com
SUPERADMIN_PASSWORD=password

# Timeout impersonation dalam menit (0 = tanpa batas)
IMPERSONATION_TIMEOUT_MINUTES=0

# Aktifkan Content-Security-Policy (uji dulu di staging)
SECURITY_CSP_ENABLED=false

# Two-factor authentication (TOTP)
TWO_FACTOR_ENABLED=false

# Monitoring (opsional — butuh sentry/sentry-laravel)
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=0.0

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

AI_PROVIDER=
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=

POSTMARK_API_KEY=
RESEND_API_KEY=

SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_BOT_USER_DEFAULT_CHANNEL=
